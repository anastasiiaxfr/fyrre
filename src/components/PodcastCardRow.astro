---
import Image from "astro/components/Image.astro";
import { formatDate } from "../utils/dateFormatter";

const { index, title, _createdAt, duration, episod, slug, image } = Astro.props;
const locale = Astro.currentLocale;
---

<article>
  <a
    href={`/${locale}/podcast/${slug}`}
    class="grid grid-cols-1 sm:grid-cols-[25px_240px_1fr] sm:text-left lg:grid-cols-[25px_240px_1fr] gap-10 items-center"
  >
    <div class="text-3xl font-semibold">
      {String(index + 1).padStart(2, "0")}
    </div>
    <div class="grid">
     {image && <Image
        src={image}
        alt={title}
        width="240"
        height="240"
        format="webp"
        quality={80}
        class="w-full h-auto [grid-area:1/1/2/2]"
      />} 
      <div
        class="flex flex-col justify-between [grid-area:1/1/2/2] text-white p-4"
      >
        <div>
          <p class="text-5xl xl:text-5xl leading-[0.8]">FYRRE</p>
          <p class="uppercase text-lg xl:text-xl mt-2">Podcast</p>
        </div>

        <div class="flex justify-between items-end">
          <div>
            <p class="text-3xl uppercase">
              Ep{" "}
              {episod < 10 ? `0${episod}` : episod}
            </p>
          </div>
          <div>
            <Image src="/img/icons/arrow.svg" alt="" width="46" height="46" />
          </div>
        </div>
      </div>
    </div>

    <div class="mx-auto lg:mx-0 flex flex-wrap justify-between items-center">
      <h3 class="mb-0">{title}</h3>

      <div
        class="flex flex-wrap gap-x-6 gap-y-3 justify-start items-center mt-4"
      >
        <p>
          <b class="mr-2">Date</b>
          <span>{formatDate(_createdAt)} </span>
        </p>
        <p>
          <b class="mr-2">Duration</b>
          <span>{duration} Min</span>
        </p>
        <button
          class="btn btn-link text-inherit uppercase no-underline group p-0"
        >
          Listen
          <i class="fa-solid fa-arrow-right group-hover:translate-x-1"></i>
        </button>
      </div>
    </div>
  </a>
</article>
