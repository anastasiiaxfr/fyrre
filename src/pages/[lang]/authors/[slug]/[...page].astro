---
import Layout from "../../../../layouts/Base.astro";
import { client } from "../../../../lib/sanity";
import Card from "../../../../components/AuthorBlogCard.astro";
import PortableComponent from "../../../../components/builder/PortableComponent.astro";
import Pagination from "../../../../components/Pagination.astro";

import { LOCALES } from "../../../../i18n";

export async function getStaticPaths({ paginate }) {
  const paths = [];

  for (const lang of Object.keys(LOCALES)) {
    const authors = await client.fetch(
      `
      *[
        _type == "author"
        && language == $lang
      ]{
        name,
        description,
        city,
        job,
        bio,
        language,
        translationGroup,
        "slug": slug.current,
        "image": image.asset->url
      }
      `,
      { lang }
    );

    for (const author of authors) {
      if (!author.translationGroup) continue;

      const translations = await client.fetch(
        `
        *[
          _type == "author"
          && translationGroup == $group
        ]{
          language,
          "slug": slug.current
        }
        `,
        { group: author.translationGroup }
      );

      const translationMap = {};

      for (const t of translations) {
        if (t.language && t.slug) {
          translationMap[t.language] =
            `/${t.language}/authors/${t.slug}`;
        }
      }

      const posts = await client.fetch(
        `
        *[
          _type == "post"
          && language == $lang
          && author->slug.current == $slug
        ]
        | order(_createdAt desc){
          title,
          duration,
          _createdAt,
          "slug": slug.current,
          "image": thumbnail.asset->url
        }
        `,
        {
          lang,
          slug: author.slug,
        }
      );

      const paginated = paginate(posts, {
        pageSize: 4,

        params: {
          lang,
          slug: author.slug,
        },

        props: {
          author,
          translations: translationMap, 
        },
      });

      paths.push(...paginated);
    }
  }

  return paths;
}

const locale = Astro.params.lang;

const { page, author, translations } = Astro.props;

if (!author) {
  throw new Error("Author not found");
}


const posts = page.data;

const currentPage = page.currentPage;

const totalPages = page.lastPage;

const socials = [
  {
    url: "#",
    title: "Instagram",
    icon: "fa-brands fa-instagram",
  },
  {
    url: "#",
    title: "Twitter",
    icon: "fa-brands fa-x-twitter",
  },
  {
    url: "#",
    title: "Youtube",
    icon: "fa-brands fa-youtube",
  },
];
---

<Layout
  title={author.name}
  description={author.description}
  image={author?.image || ""}
  translations={translations}
>
  <section class="mt-10">
    <div class="container">
      <div class="flex items-center justify-between flex-wrap gap-4">
        <a
          href={`/${locale}/authors`}
          class="btn btn-link text-inherit uppercase no-underline group p-0"
        >
          <i class="fa-solid fa-arrow-left group-hover:translate-x-1"></i>
          Go Back
        </a>

        <p class="font-semibold text-3xl uppercase">Author</p>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div
        class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-[350px_1fr] gap-x-20 gap-y-10"
      >
        <aside>
          {
            author && (
              <img
                src={author.image}
                alt={author.name}
                class="rounded-full h-auto mx-auto w-full max-w-[350px] aspect-square object-cover"
              />
            )
          }

          <div
            class="border-t pt-5 mt-10 flex flex-wrap items-center justify-between gap-4"
          >
            <p class="font-semibold uppercase">Follow</p>

            <nav class="flex items-center gap-3 flex-wrap">
              {
                socials.map((icon) => (
                  <a
                    href={icon.url}
                    title={icon.title}
                    class="hover:rotate-12"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <i class={icon.icon} />
                  </a>
                ))
              }
            </nav>
          </div>
        </aside>

        <div>
          <div class="max-w-md">
            <h1 class="mb-6">{author.name}</h1>

            <div class="flex flex-wrap gap-x-6 gap-y-3 items-center">
              <p>
                <b class="mr-2">Job</b>
                <span>{author.job}</span>
              </p>

              <p>
                <b class="mr-2">City</b>
                <span>{author.city}</span>
              </p>
            </div>
          </div>

          {
            author.description && (
              <p class="text-lg my-10 font-semibold">{author.description}</p>
            )
          }

          {
            author?.bio && (
              <div class="prose prose-lg max-w-none mt-10">
                <PortableComponent body={author.bio} />
              </div>
            )
          }
        </div>
      </div>
    </div>
  </section>
  {
    posts.length > 0 && (
      <section class="section">
        <div class="container">
          <div class="border-t pt-10">
            <h2 class="uppercase">Articles by {author.name}</h2>
            <div class="grid grid-cols-1 lg:grid-cols-2 mt-10">
              {posts.map((post) => (
                <Card {...post} />
              ))}
            </div>

            {totalPages > 1 && (
              <div class="my-10">
                <Pagination totalPages={totalPages} page={page} />
              </div>
            )}
          </div>
        </div>
      </section>
    )
  }
</Layout>
