---
const { slug, image, title, _createdAt, duration } = Astro.props;
import { formatDate } from "../utils/dateFormatter";
const locale = Astro.currentLocale;

---

<article
  class="border lg:even:border-l-0 even:border-y-0 lg:even:border-y last-of-type:border-b lg:nth-[4n+3]:border-t-0 lg:nth-[4n+4]:border-t-0 p-4 lg:p-10"
>
  <a
    href={`/${locale}/blog/${slug}`}
    class="grid lg:text-left grid-cols-[150px_1fr] gap-4 md:gap-x-10 gap-y-4 items-center"
  >
    {
      image && (
        <img
          src={image}
          alt={title}
          class="aspect-square mx-auto h-auto w-full max-w-37.5 object-cover"
        />
      )
    }

    <div class="mx-auto lg:mx-0 w-full">
      <h3 class="text-xl md:text-3xl">{title}</h3>

      <div
        class="flex flex-wrap gap-x-6 gap-y-3 justify-start items-center mt-4 text-sm md:text-base"
      >
        <p>
          <b class="mr-2">Date</b>

          <span class="hover:underline">
            {formatDate(_createdAt)}
          </span>
        </p>

        <p>
          <b class="mr-2">Read</b>
          <span>{duration} Min</span>
        </p>
      </div>
    </div>
  </a>
</article>
