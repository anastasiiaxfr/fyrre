---
import Layout from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import Topline from "../components/Topline.astro";
import Demo from "../components/DemoPost.astro";
import Posts from "../components/Posts.astro";
import Podcasts from "../components/Podcasts.astro";
import Authors from "../components/Authors.astro";
const locale = Astro.url.pathname.split("/")[1];

if (!["en", "uk", "de"].includes(locale)) {
  return Astro.redirect("/en" + Astro.url.pathname);
}
---

<Layout title="Homepage">
  <Hero title="Art & Life" />
  <Topline />
  <Demo />
  <Posts />
  <Podcasts />
  <Authors />
</Layout>
