---
import Layout from "../../../layouts/Base.astro";
import Hero from "../../../components/Hero.astro";
import PodcastCardRow from "../../../components/PodcastCardRow.astro";
import Pagination from "../../../components/Pagination.astro";
import { client } from "../../../lib/sanity";

import { LOCALES } from "../../../i18n";

export async function getStaticPaths({ paginate }) {
  const paths = [];

  for (const lang of Object.keys(LOCALES)) {
    const podcasts = await client.fetch(
      `
      *[_type == "podcast" && language == $lang]
      | order(_createdAt desc){
        title,
        _createdAt,
        duration,
        episod,
        "slug": slug.current,
        "image": mainImage.asset->url
      }
      `,
      { lang }
    );

    const paginated = paginate(podcasts, {
      pageSize: 6,

      params: {
        lang,
      },
    });

    paths.push(...paginated);
  }

  return paths;
}

const locale = Astro.params.lang;

const { page } = Astro.props;

const totalPages = Math.ceil(page.total / page.size);
---

<Layout title="Podcast">
  <Hero title="Podcast" />

  <section class="section">
    <div class="container">
      <ul class="grid gap-10 mb-10">
        {
          page.data.map((post, index) => (
            <li class="border-b pb-10 last:border-b-0 last:pb-0">
              <PodcastCardRow {...post} index={index} />
            </li>
          ))
        }
      </ul>

      {totalPages > 1 && <Pagination totalPages={totalPages} page={page} />}
    </div>
  </section>
</Layout>
