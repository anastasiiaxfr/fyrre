{
  "name": "Fyrre",
  "short_name": "Fyrre",
  "start_url": "/",
  "description": "A fast and modern starter template designed to help teams build and launch magazines, blogs, or brand websites efficiently, with a focus on performance and scalability.",
  "display_override": ["window-control-overlay", "minimal-ui"],
  "orientation": "portrait",
  "theme_color": "#ECC584",
  "background_color": "#464646",
  "display": "standalone",
